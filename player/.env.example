# Optional dev override: where to fetch config.json from.
# Defaults to /config.json (i.e. public/config.json served by Vite).
# Set to an absolute URL to point dev builds at a config served elsewhere.
# VITE_CONFIG_URL=http://localhost:8080/config.json

# Dev-only backend proxy. When set, `vite dev` proxies every request
# starting with VITE_BACKEND_BASE_PATH (default /playtesthub) to this
# URL. Lets config.json carry a same-origin grpcGatewayUrl and sidesteps
# the browser cross-origin policy without requiring CORS on the backend.
# No effect on `npm run build` — production bundles are static.
#
# Matching config.json for a local backend then looks like:
#   { "grpcGatewayUrl": "http://localhost:5173/playtesthub", ... }
#
# See docs/engineering.md §7 "Player end-to-end demo against a local
# backend" for the full local-demo walkthrough.
# VITE_BACKEND_URL=http://localhost:8000
# VITE_BACKEND_BASE_PATH=/playtesthub
