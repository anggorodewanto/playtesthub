{
  "name": "playtesthub-player",
  "description": "playtesthub player app — Svelte static bundle for self-hosting on GitHub Pages / Vercel.",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "svelte-check --tsconfig ./tsconfig.json && vite build",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint .",
    "format": "prettier --write \"src/**/*.{ts,svelte,css}\" \"tests/**/*.{ts,svelte}\""
  },
  "devDependencies": {
    "@sveltejs/vite-plugin-svelte": "5.0.3",
    "@tailwindcss/vite": "4.0.17",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/svelte": "5.2.7",
    "@testing-library/user-event": "14.5.2",
    "@types/node": "22.10.7",
    "eslint": "9.18.0",
    "globals": "15.14.0",
    "jsdom": "26.0.0",
    "prettier": "3.4.2",
    "prettier-plugin-svelte": "3.3.3",
    "svelte": "5.19.0",
    "svelte-check": "4.1.4",
    "tailwindcss": "4.0.17",
    "tslib": "2.8.1",
    "typescript": "5.7.3",
    "typescript-eslint": "8.20.0",
    "vite": "6.0.7",
    "vitest": "2.1.8"
  }
}
