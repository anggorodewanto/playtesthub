{
  "name": "playtesthub-admin",
  "description": "playtesthub Extend App UI — React 19 + Vite Module Federation remote rendered inside the AGS Admin Portal.",
  "private": true,
  "version": "0.1.0",
  "type": "module",
  "scripts": {
    "dev": "vite",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "preview": "vite preview",
    "test": "vitest run",
    "test:watch": "vitest",
    "format": "prettier --write src/**/*",
    "format:swaggers": "prettier --write swaggers/**/*",
    "cg:prettify": "prettier --write --no-error-on-unmatched-pattern src/playtesthubapi/**/*",
    "cg:generate": "accelbyte-codegen generate-code --config swaggers.json --swaggersOutput swaggers --output src/playtesthubapi",
    "cg:download": "accelbyte-codegen download-swaggers --config swaggers.json --swaggersOutput swaggers && npm run format:swaggers",
    "cg:clean-and-generate": "rimraf src/playtesthubapi && npm run cg:generate && npm run cg:prettify",
    "codegen": "npm run cg:download && npm run cg:clean-and-generate"
  },
  "dependencies": {
    "@accelbyte/sdk": "4.3.0",
    "@accelbyte/sdk-extend-app-ui": "0.2.0",
    "@accelbyte/sdk-iam": "6.3.3",
    "@accelbyte/validator": "0.2.30",
    "@module-federation/vite": "1.11.1",
    "@tanstack/react-query": "5.90.21",
    "antd": "6.3.1",
    "axios": "1.13.6",
    "react": "19.2.0",
    "react-dom": "19.2.0",
    "react-router": "7.13.1"
  },
  "devDependencies": {
    "@accelbyte/codegen": "4.2.1",
    "@eslint/js": "9.39.1",
    "@tailwindcss/vite": "4.2.1",
    "@testing-library/jest-dom": "6.6.3",
    "@testing-library/react": "16.1.0",
    "@testing-library/user-event": "14.5.2",
    "@types/http-proxy": "1.17.17",
    "@types/node": "24.10.1",
    "@types/react": "19.2.7",
    "@types/react-dom": "19.2.3",
    "@vitejs/plugin-react": "5.1.1",
    "eslint": "9.39.1",
    "eslint-plugin-react-hooks": "7.0.1",
    "eslint-plugin-react-refresh": "0.4.24",
    "globals": "16.5.0",
    "http-proxy": "1.18.1",
    "jsdom": "25.0.1",
    "prettier": "3.8.1",
    "prettier-plugin-organize-imports": "4.3.0",
    "rimraf": "6.1.3",
    "tailwindcss": "4.2.1",
    "typescript": "~5.9.3",
    "typescript-eslint": "8.48.0",
    "vite": "7.1.7",
    "vitest": "2.1.8",
    "zod": "3.25.76"
  },
  "overrides": {
    "axios": "1.13.6",
    "zod": "3.25.76"
  }
}
